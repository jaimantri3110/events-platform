# ── Core ──────────────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_SETTINGS_MODULE=config.settings.dev

# ── Database ───────────────────────────────────────────────────────────────────
# Docker Compose default (matches docker-compose.yml service names)
DATABASE_URL=postgres://events_user:events_password@db:5432/events_db
# Railway auto-injects DATABASE_URL when a Postgres plugin is attached.

# ── Redis / Celery ─────────────────────────────────────────────────────────────
# Docker Compose default
REDIS_URL=redis://redis:6379/0
# Railway auto-injects REDIS_URL when a Redis plugin is attached.
# The app reads REDIS_URL first; override with the variables below if needed.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@eventsplatform.com

# ── Network ────────────────────────────────────────────────────────────────────
# Comma-separated list; Railway also reads RAILWAY_PUBLIC_DOMAIN automatically.
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Misc ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# PORT is injected by Railway at runtime — do NOT set it here.
